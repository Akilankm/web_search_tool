# Fresh Azure ML setup:
#   cp .env.example .env
#   edit only the real SerpAPI and LLM credential values
#   ./scripts/azureml_startup.sh
#   open notebooks/01_run_product_evidence.ipynb
#
# The default feature schema is already included at:
#   inputs/private/toy_features.json
# No feature-file copy or creation step is required.
#
# The startup script attempts chmod 600 automatically. On Azure ML managed
# mounts that cannot preserve POSIX mode 0600, it switches automatically to the
# documented trusted-workspace fallback. No extra startup flag is required.

# Required search credential
SERPAPI_API_KEY=replace_with_real_serpapi_key

# Strict three-stage discovery contract
# Credit 1: requested retailer in requested country (or primary country search)
# Credit 2: alternative retailers within requested country
# Credit 3: global fallback
PRODUCT_HARNESS_WORKFLOW=three_stage_feature_aware
PRODUCT_HARNESS_MAX_ORGANIC_SEARCHES=3
PRODUCT_HARNESS_MAX_AI_MODE_SEARCHES=0
PRODUCT_HARNESS_SERP_RESULTS=100
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_PLANNING=false
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_FEEDBACK=false

# Precision-gated acquisition
# SERP recall is preserved, but only qualified canonical product-page URLs are
# fully scraped. The six-scrape budget is shared across all three searches and
# unused capacity rolls forward. No domain may consume more than two scrapes.
PRODUCT_HARNESS_MAX_FULL_SCRAPES=6
PRODUCT_HARNESS_MAX_SCRAPES_PER_DOMAIN=2
PRODUCT_HARNESS_MIN_PREFLIGHT_SCORE=0.28
PRODUCT_HARNESS_MAX_SCRAPES=6
PRODUCT_HARNESS_SCRAPE_TOP_K_PER_STAGE=2
PRODUCT_HARNESS_MAX_CANDIDATE_POOL=90
PRODUCT_HARNESS_SCRAPE_CONCURRENCY=4
PRODUCT_HARNESS_STATIC_FETCH_FIRST=true
PRODUCT_HARNESS_BROWSER_FALLBACK_ONLY=false
PRODUCT_HARNESS_STATIC_TIMEOUT_SECONDS=10
PRODUCT_HARNESS_CRAWL_PAGE_TIMEOUT_MS=45000

# Context-efficient LLM-controlled browser investigation
# Only high-potential, already-scraped, unresolved product-page candidates are
# admitted. Runtime hard ceilings remain 3 candidates, 4 turns and 6 actions
# even when an older .env contains larger legacy values.
PRODUCT_HARNESS_ENABLE_AGENTIC_BROWSER=true
PRODUCT_HARNESS_REQUIRE_AGENTIC_BROWSER=true
PRODUCT_HARNESS_MAX_AGENTIC_CANDIDATES=3
PRODUCT_HARNESS_AGENTIC_MAX_TURNS_PER_CANDIDATE=4
PRODUCT_HARNESS_AGENTIC_MAX_ACTIONS_PER_CANDIDATE=6
PRODUCT_HARNESS_AGENTIC_OBSERVATION_CHARS=4000
PRODUCT_HARNESS_AGENTIC_MAX_ELEMENTS=15
PRODUCT_HARNESS_AGENTIC_MAX_IMAGES=8
PRODUCT_HARNESS_AGENTIC_IMAGE_DETAIL=high

# Final product URL acceptance policy
PRODUCT_HARNESS_COUNTRY_FIRST=true
PRODUCT_HARNESS_ALLOW_GLOBAL_FALLBACK=true
PRODUCT_HARNESS_REQUIRE_ALL_FEATURES_ON_PRIMARY=true
PRODUCT_HARNESS_REJECT_EXPIRING_URLS=true
PRODUCT_HARNESS_ALLOW_EAN_CONFLICT=false
PRODUCT_HARNESS_RETURN_REJECTED_REFERENCE_AS_PRODUCT_URL=false
PRODUCT_HARNESS_MIN_VERIFIED_CONFIDENCE=0.80
PRODUCT_HARNESS_MIN_REVIEW_CONFIDENCE=0.30

# Compose and browser service
AGENT_HOST_PORT=8788
AGENT_WORKERS=2
STACK_STARTUP_TIMEOUT_SECONDS=300
BROWSER_MAX_CONTEXTS=3
BROWSER_NAVIGATION_TIMEOUT_MS=60000
BROWSER_ACTION_TIMEOUT_MS=8000
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=1100
BROWSER_MIN_IMAGE_WIDTH=240
BROWSER_MIN_IMAGE_HEIGHT=240
BROWSER_MAX_ASSET_BYTES=12582912
BROWSER_CONNECT_TIMEOUT_SECONDS=5
BROWSER_READ_TIMEOUT_SECONDS=180
BROWSER_CLIENT_MAX_RETRIES=2
PRODUCT_HARNESS_ENABLE_BROWSER_SERVICE=true
PRODUCT_HARNESS_BROWSER_CANDIDATE_LIMIT=3
PRODUCT_HARNESS_ENABLE_VISION_REASONING=true
PRODUCT_HARNESS_REQUIRE_MULTIMODAL_FOR_READY=false

# Container output paths
PRODUCT_HARNESS_OUTPUT_DIR=/data/artifacts
PRODUCT_HARNESS_WRITE_OUTPUTS=true
PRODUCT_HARNESS_WRITE_REVIEW_PACK=true
PRODUCT_HARNESS_WRITE_MARKDOWN_REPORTS=false
PRODUCT_HARNESS_WRITE_TRACE_JSON=false
PRODUCT_HARNESS_WRITE_DEBUG_CSVS=false

# Optional semantic reasoning over already-scraped text. The agentic browser LLM
# remains required even when this post-scrape helper is disabled.
PRODUCT_HARNESS_ENABLE_LLM_FEATURE_REASONING=false
PRODUCT_HARNESS_LLM_MAX_CALLS_PER_PRODUCT=2

# Required by the LLM-controlled browser agent and vision reasoning.
# Equivalent AZURE_OPENAI_* variable names are also accepted.
# Enterprise-issued values are treated as opaque: the bootstrap checks only that
# API key, API version, endpoint, and deployment are present. It does not impose
# minimum key length, HTTPS/URL-shape rules, or deployment-name restrictions.
# The actual provider/client request remains the source of truth for validity.
LLM_API_KEY=replace_with_real_llm_api_key
LLM_API_VERSION=replace_with_supported_api_version
LLM_ENDPOINT=replace_with_enterprise_llm_endpoint
LLM_DEPLOYMENT=replace_with_enterprise_deployment
LLM_CONSUMER_ID=
LLM_MAX_TOKENS=1600
LLM_TEMPERATURE=0.0
LLM_CONNECT_TIMEOUT=15
LLM_READ_TIMEOUT=120
LLM_MAX_RETRIES=2
