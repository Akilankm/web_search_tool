# =============================================================================
# Product Evidence Harness — secure environment template
# =============================================================================
# 1. Copy this file to .env
# 2. Replace every placeholder secret
# 3. Restrict local permissions before running:
#       chmod 600 .env
#
# Never commit .env. The application validates this configuration before any
# paid SerpAPI or LLM request and fails closed on unsafe or ambiguous settings.

# -----------------------------------------------------------------------------
# REQUIRED: SerpAPI credential
# -----------------------------------------------------------------------------
SERPAPI_API_KEY=replace_with_real_serpapi_key

# -----------------------------------------------------------------------------
# REQUIRED PRODUCTION WORKFLOW INVARIANTS
# -----------------------------------------------------------------------------
PRODUCT_HARNESS_WORKFLOW=one_credit_feature_aware

# Search is identity-driven and limited to exactly one Google SerpAPI request.
PRODUCT_HARNESS_ENABLE_TOURNAMENT_MODE=false
PRODUCT_HARNESS_MAX_ORGANIC_SEARCHES=1
PRODUCT_HARNESS_MAX_AI_MODE_SEARCHES=0
PRODUCT_HARNESS_SERP_RESULTS=100

# LLMs must never plan searches, generate search queries, or trigger a second
# provider call in the one-credit workflow.
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_PLANNING=false
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_FEEDBACK=false

# -----------------------------------------------------------------------------
# SCRAPING AND EVIDENCE LIMITS
# -----------------------------------------------------------------------------
PRODUCT_HARNESS_MAX_SCRAPES=8
PRODUCT_HARNESS_MAX_CANDIDATE_POOL=30
PRODUCT_HARNESS_SCRAPE_CONCURRENCY=4
PRODUCT_HARNESS_STATIC_FETCH_FIRST=true
PRODUCT_HARNESS_BROWSER_FALLBACK_ONLY=true
PRODUCT_HARNESS_STATIC_TIMEOUT_SECONDS=10
PRODUCT_HARNESS_CRAWL_PAGE_TIMEOUT_MS=45000

# Exact-product and market policy.
PRODUCT_HARNESS_COUNTRY_FIRST=true
PRODUCT_HARNESS_ALLOW_GLOBAL_FALLBACK=true
PRODUCT_HARNESS_ALLOW_EAN_CONFLICT=true
PRODUCT_HARNESS_RETURN_REJECTED_REFERENCE_AS_PRODUCT_URL=false
PRODUCT_HARNESS_MIN_VERIFIED_CONFIDENCE=0.80
PRODUCT_HARNESS_MIN_REVIEW_CONFIDENCE=0.30

# -----------------------------------------------------------------------------
# OUTPUTS
# -----------------------------------------------------------------------------
PRODUCT_HARNESS_OUTPUT_DIR=output
PRODUCT_HARNESS_WRITE_OUTPUTS=true
PRODUCT_HARNESS_WRITE_REVIEW_PACK=true
PRODUCT_HARNESS_WRITE_MARKDOWN_REPORTS=false
PRODUCT_HARNESS_WRITE_TRACE_JSON=false
PRODUCT_HARNESS_WRITE_DEBUG_CSVS=false

# Optional custom country profiles.
# PRODUCT_HARNESS_COUNTRY_PROFILES=src/product_evidence_harness/configs/country_profiles.json

# -----------------------------------------------------------------------------
# OPTIONAL: POST-SCRAPE LLM FEATURE REASONING
# -----------------------------------------------------------------------------
# Disabled by default. When enabled, the LLM receives only already-scraped page
# evidence. It cannot search, follow URLs, or override failed identity checks.
# Returned evidence is accepted only when its quote is found in the scraped text.
PRODUCT_HARNESS_ENABLE_LLM_FEATURE_REASONING=false
PRODUCT_HARNESS_LLM_MAX_CALLS_PER_PRODUCT=2

# Recommended generic/internal Azure-OpenAI-compatible gateway variables.
# These are required only when PRODUCT_HARNESS_ENABLE_LLM_FEATURE_REASONING=true.
LLM_API_KEY=replace_with_real_llm_api_key
LLM_API_VERSION=replace_with_supported_api_version
LLM_ENDPOINT=https://replace-with-approved-llm-endpoint.example.com/
LLM_DEPLOYMENT=replace_with_approved_deployment
LLM_CONSUMER_ID=replace_with_consumer_id_if_required

# Generation and transport controls.
LLM_MAX_TOKENS=1600
LLM_TEMPERATURE=0.0
LLM_CONNECT_TIMEOUT=15
LLM_READ_TIMEOUT=120
LLM_MAX_RETRIES=2

# Azure-prefixed aliases are also supported, but do not define both alias sets
# with different values. Conflicting aliases are rejected before execution.
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=
# AZURE_OPENAI_CONSUMER_ID=
