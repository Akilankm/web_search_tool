# Copy this file to .env, replace every placeholder, then run:
#   chmod 600 .env
#   ./scripts/azureml_startup.sh

# Required search credential
SERPAPI_API_KEY=replace_with_real_serpapi_key

# One-credit discovery contract
PRODUCT_HARNESS_WORKFLOW=one_credit_feature_aware
PRODUCT_HARNESS_MAX_ORGANIC_SEARCHES=1
PRODUCT_HARNESS_MAX_AI_MODE_SEARCHES=0
PRODUCT_HARNESS_SERP_RESULTS=100
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_PLANNING=false
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_FEEDBACK=false

# Agent-side static extraction. Interactive rendering belongs only to the
# dedicated browser container.
PRODUCT_HARNESS_MAX_SCRAPES=8
PRODUCT_HARNESS_MAX_CANDIDATE_POOL=30
PRODUCT_HARNESS_SCRAPE_CONCURRENCY=4
PRODUCT_HARNESS_STATIC_FETCH_FIRST=true
PRODUCT_HARNESS_BROWSER_FALLBACK_ONLY=false
PRODUCT_HARNESS_STATIC_TIMEOUT_SECONDS=10
PRODUCT_HARNESS_CRAWL_PAGE_TIMEOUT_MS=45000

# Product identity and source-selection policy
PRODUCT_HARNESS_COUNTRY_FIRST=true
PRODUCT_HARNESS_ALLOW_GLOBAL_FALLBACK=true
PRODUCT_HARNESS_ALLOW_EAN_CONFLICT=false
PRODUCT_HARNESS_RETURN_REJECTED_REFERENCE_AS_PRODUCT_URL=false
PRODUCT_HARNESS_MIN_VERIFIED_CONFIDENCE=0.80
PRODUCT_HARNESS_MIN_REVIEW_CONFIDENCE=0.30

# Compose and browser service
AGENT_HOST_PORT=8788
AGENT_WORKERS=2
STACK_STARTUP_TIMEOUT_SECONDS=300
BROWSER_MAX_CONTEXTS=3
BROWSER_NAVIGATION_TIMEOUT_MS=60000
BROWSER_ACTION_TIMEOUT_MS=8000
BROWSER_VIEWPORT_WIDTH=1440
BROWSER_VIEWPORT_HEIGHT=1100
BROWSER_MIN_IMAGE_WIDTH=240
BROWSER_MIN_IMAGE_HEIGHT=240
BROWSER_MAX_ASSET_BYTES=12582912
PRODUCT_HARNESS_ENABLE_BROWSER_SERVICE=true
PRODUCT_HARNESS_BROWSER_CANDIDATE_LIMIT=3
PRODUCT_HARNESS_ENABLE_VISION_REASONING=true
PRODUCT_HARNESS_REQUIRE_MULTIMODAL_FOR_READY=false

# Container output paths
PRODUCT_HARNESS_OUTPUT_DIR=/data/artifacts
PRODUCT_HARNESS_WRITE_OUTPUTS=true
PRODUCT_HARNESS_WRITE_REVIEW_PACK=true
PRODUCT_HARNESS_WRITE_MARKDOWN_REPORTS=false
PRODUCT_HARNESS_WRITE_TRACE_JSON=false
PRODUCT_HARNESS_WRITE_DEBUG_CSVS=false

# Optional semantic reasoning over already-scraped text
PRODUCT_HARNESS_ENABLE_LLM_FEATURE_REASONING=false
PRODUCT_HARNESS_LLM_MAX_CALLS_PER_PRODUCT=2

# Required when vision or semantic reasoning is enabled
LLM_API_KEY=replace_with_real_llm_api_key
LLM_API_VERSION=replace_with_supported_api_version
LLM_ENDPOINT=https://replace-with-approved-llm-endpoint.example.com/
LLM_DEPLOYMENT=replace_with_approved_vision_deployment
LLM_CONSUMER_ID=
LLM_MAX_TOKENS=1600
LLM_TEMPERATURE=0.0
LLM_CONNECT_TIMEOUT=15
LLM_READ_TIMEOUT=120
LLM_MAX_RETRIES=2
