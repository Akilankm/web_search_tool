# ---------------------------------------------------------------------------
# Search provider
# ---------------------------------------------------------------------------
SERPAPI_API_KEY=your_serpapi_key

# ---------------------------------------------------------------------------
# LLM-guided Product Evidence Harness behavior
# ---------------------------------------------------------------------------
# Master switch: LLM is the brain/controller when enabled.
PRODUCT_HARNESS_ENABLE_LLM=true

# Search planning / feedback: LLM plans queries before SerpAPI and refines them after weak candidates.
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_PLANNING=true
PRODUCT_HARNESS_ENABLE_LLM_SEARCH_FEEDBACK=true
PRODUCT_HARNESS_LLM_SEARCH_PLAN_MAX_QUERIES=6
PRODUCT_HARNESS_LLM_SEARCH_FEEDBACK_MAX_QUERIES=4
PRODUCT_HARNESS_LLM_SEARCH_FEEDBACK_MAX_ROUNDS=2

# Post-scrape exact-product adjudication.
PRODUCT_HARNESS_ENABLE_LLM_ADJUDICATION=true
PRODUCT_HARNESS_REQUIRE_LLM_EXACT_MATCH=true
PRODUCT_HARNESS_LLM_ADJUDICATE_TOP_K=3

# Hard cap across search planning + search feedback + exact-product adjudication.
PRODUCT_HARNESS_LLM_MAX_CALLS_PER_PRODUCT=4

# Vision constraints: one image per call only; payload is reduced if gateway rejects.
PRODUCT_HARNESS_LLM_USE_IMAGES=true
PRODUCT_HARNESS_LLM_IMAGE_DETAIL=high
PRODUCT_HARNESS_LLM_PAYLOAD_REDUCTION=true


# Exactness engine: detector-based conflict gates are always active.
# Input EAN must be supplied/read as text; do not let Excel convert it to scientific notation.
# Return one best available URL whenever any candidate exists, while separately exposing verified_exact_url.
PRODUCT_HARNESS_RETURN_BEST_AVAILABLE_URL=true

# Country-first discovery with global fallback.
PRODUCT_HARNESS_COUNTRY_FIRST=true
PRODUCT_HARNESS_ALLOW_GLOBAL_FALLBACK=true

# Optional harness limits / output
PRODUCT_HARNESS_MAX_ORGANIC_SEARCHES=3
PRODUCT_HARNESS_MAX_AI_MODE_SEARCHES=1
PRODUCT_HARNESS_MAX_SCRAPES=180
PRODUCT_HARNESS_MAX_ITERATIONS=240
PRODUCT_HARNESS_SERP_RESULTS=100
PRODUCT_HARNESS_MAX_CANDIDATE_POOL=300
PRODUCT_HARNESS_OUTPUT_DIR=output
PRODUCT_HARNESS_WRITE_OUTPUTS=true
PRODUCT_HARNESS_WRITE_MARKDOWN_REPORTS=true
PRODUCT_HARNESS_WRITE_TRACE_JSON=true
PRODUCT_HARNESS_WRITE_DEBUG_CSVS=false
# PRODUCT_HARNESS_COUNTRY_PROFILES=src/product_evidence_harness/configs/country_profiles.json

# EAN is a strong user-provided anchor, not a sole decision-maker.
# The LLM must never invent/suggest/correct EAN. This flag allows retailer EAN conflict
# to be handled as warning when exact product text/form is otherwise established.
PRODUCT_HARNESS_ALLOW_EAN_CONFLICT=true

# ---------------------------------------------------------------------------
# Azure OpenAI / internal LLM gateway
# The service accepts either AZURE_OPENAI_* names or LLM_* aliases.
# ---------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your_azure_openai_api_key
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=your_vision_enabled_deployment

# Optional org gateway header. The service sends this as X-NIQ-CIS-Consumer when set.
LLM_CONSUMER_ID=your_consumer_id

# Optional LLM runtime tuning
LLM_MAX_TOKENS=1600
LLM_TEMPERATURE=0.0
LLM_CONNECT_TIMEOUT=15
LLM_READ_TIMEOUT=120
LLM_MAX_RETRIES=3

# Hardening controls added after repo retrospective
# Keep one LLM call available for exact-product adjudication; search planning/repair cannot consume all calls.
PRODUCT_HARNESS_RESERVE_LLM_CALL_FOR_ADJUDICATION=true

# True global fallback: global queries omit country gl; these control global search language/country override if needed.
PRODUCT_HARNESS_GLOBAL_FALLBACK_LANGUAGE=en
# Leave blank for true global; set e.g. US only if you explicitly want a default global market.
PRODUCT_HARNESS_GLOBAL_FALLBACK_COUNTRY=

# Product URL policy: by default a hard-rejected/sibling variant is not returned as product_url.
# It is written as best_reference_url for audit/review instead.
PRODUCT_HARNESS_RETURN_REJECTED_REFERENCE_AS_PRODUCT_URL=false

# Optional external configs replacing built-in generic lexicons/signals.
PRODUCT_HARNESS_PRODUCT_IDENTITY_TAXONOMY=src/product_evidence_harness/configs/product_identity_taxonomy.json

# Requested retailer strategy
# Retailer is a preferred first evidence source, not a hard constraint.
# If requested retailer pages are non-scrapable/thin/wrong, the harness escapes to other retailers in-country, then global fallback.
PRODUCT_HARNESS_REQUESTED_RETAILER_FIRST=true
PRODUCT_HARNESS_REQUESTED_RETAILER_MIN_SCRAPES_FOR_ESCAPE=2
PRODUCT_HARNESS_REQUESTED_RETAILER_MIN_RICHNESS_FOR_EVIDENCE=0.30
